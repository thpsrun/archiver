# Django API
API_BASE_URL=https://your-django-app.com/api
API_KEY=your-api-key

# BackBlaze B2
B2_APPLICATION_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-key
B2_BUCKET_NAME=your-bucket

# Sentry (optional - leave empty to disable)
SENTRY_DSN=

# Archive URL (optional - if the B2 bucket is behind a CDN then you can use this; leave empty to disable)
ARCHIVE_URL=

# Testing (optional - skips all API calls when true, use with test_videos.txt)
SKIP_API=false

# Throttling (optional - uncomment to change)
# DOWNLOAD_RATE_LIMIT=5M
# DELAY_MIN_SECONDS=30
# DELAY_MAX_SECONDS=90
# CONSECUTIVE_FAILURE_THRESHOLD=5

# Retry (optional - uncomment to change)
# RETRY_PASSES=3
# RETRY_DELAY_SECONDS=120

# Paths (optional - uncomment to change)
# DATA_DIR=/app/data
# YTDLP_CONFIG_PATH=/app/yt-dlp.conf
